# Intelligenz: Umgebungs-Variablen
# Kopier diese Datei nach .env und trag deine Keys ein.

# =============================================================
# MEETING-RECORDER (wähl einen, den anderen leer lassen)
# =============================================================

# Variante A: Fireflies.ai
# Key holen unter: https://app.fireflies.ai/integrations, dann API & Webhooks, API Key kopieren
FIREFLIES_API_KEY=

# Variante B: Fathom
# Key holen unter: https://app.fathom.ai/settings, dann Integrations, API, Generate API Key
FATHOM_API_KEY=

# =============================================================
# SLACK (optional, weglassen wenn du Slack nicht nutzt)
# =============================================================

# Slack Bot User OAuth Token (beginnt mit xoxb- oder xoxp-)
# Slack-App anlegen unter: https://api.slack.com/apps
# Benötigte Scopes: channels:history, channels:read, channels:join, users:read
# Mehrere Workspaces gehen, dazu einfach weitere SLACK_TOKEN_-Variablen anlegen
SLACK_TOKEN_MAIN=
