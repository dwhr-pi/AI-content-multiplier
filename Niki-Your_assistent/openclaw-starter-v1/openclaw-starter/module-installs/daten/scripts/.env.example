# Daten: Umgebungs-Konfiguration
# Trag Werte für die Datenquellen ein, die du anbinden willst.
# Leere Werte werden übersprungen. Du füllst nur aus, was du nutzt.

# --- YouTube ---
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# --- Stripe ---
# Ein Key pro Konto: STRIPE_API_KEY_MAIN, STRIPE_API_KEY_SAAS, usw.
# Nimm eingeschränkte Read-Only-Keys: dashboard.stripe.com/apikeys
STRIPE_API_KEY_MAIN=

# --- Google Service Account ---
# Genutzt von: Google Analytics, Google Sheets
# Anlegen unter: console.cloud.google.com > IAM & Admin > Service Accounts
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/google-service-account.json

# --- Google Analytics ---
# Property-ID findest du unter: analytics.google.com > Verwaltung > Property-Einstellungen
GA4_PROPERTY_ID=

# --- Google Sheets ---
# Aus der Tabellen-URL kopieren (zwischen /d/ und /edit)
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=

# --- Bitly ---
# Zugangs-Token unter: app.bitly.com/settings/api/
BITLY_ACCESS_TOKEN=
