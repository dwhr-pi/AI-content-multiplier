# ═══════════════════════════════════════════════════════════════════════════════
# CEO-GPT Starter-Kit: Umgebungs-Variablen
# ═══════════════════════════════════════════════════════════════════════════════
#
# Diese Datei speichert deine API-Keys. Sie ist PRIVAT, nie weitergeben, nie committen.
#
# So funktioniert das:
# - Jedes Modul sagt dir welche Keys es braucht
# - Du fügst deinen Key nach dem = ein (ohne Anführungszeichen)
# - Beispiel: OPENAI_API_KEY=sk-abc123...
#
# Du brauchst nicht ALLE auf einmal. Fang mit den Keys an die [EMPFOHLEN] markiert sind
# und füg weitere hinzu, wenn ein Modul sie braucht.
#
# ═══════════════════════════════════════════════════════════════════════════════


# ─── KERN-KI-MODELLE ─────────────────────────────────────────────────────────
# Diese treiben den Großteil von dem an, was dein CEO-GPT macht. Früh einrichten.

# [EMPFOHLEN] Anthropic: treibt Claude Code selbst plus alle Mitarbeiter-Pipelines
# Holen unter: https://console.anthropic.com/settings/keys
# "Create Key" klicken, kopieren (beginnt mit sk-ant-)
# Genutzt von: Stimme, Daily Brief, Mitarbeiter-Worker
ANTHROPIC_API_KEY=

# [EMPFOHLEN] OpenAI: Whisper-Transkription, Bilder, Text-zu-Sprache, Embeddings
# Holen unter: https://platform.openai.com/api-keys
# "Create new secret key" klicken, kopieren (beginnt mit sk-)
# Genutzt von: Daten (Transkription), Bilder, Voice-Features
OPENAI_API_KEY=

# [EMPFOHLEN] Google Gemini: lange Dokumente analysieren (1 Mio Tokens), Bilder
# Holen unter: https://aistudio.google.com/apikey
# "Create API key" klicken, kopieren (beginnt mit AI...)
# Genutzt von: Intelligenz (Meeting-Analyse), Daily Brief, Thumbnail-Generator
GEMINI_API_KEY=


# ─── DATENQUELLEN ────────────────────────────────────────────────────────────
# Verbinde deine Business-Tools. Daten führt dich Schritt für Schritt durch.

# YouTube Data API: Channel-Statistiken, Video-Metriken, Abonnenten
# Holen unter: https://console.cloud.google.com/apis/credentials
# Erst "YouTube Data API v3" aktivieren, dann API-Key anlegen
# Genutzt von: Daten (YouTube-Sammler)
YOUTUBE_API_KEY=

# Stripe: Umsatz, Abos, Zahlungen
# Holen unter: https://dashboard.stripe.com/apikeys
# "Secret key" kopieren (beginnt mit sk_live_ oder sk_test_)
# Genutzt von: Daten (Stripe-Sammler)
STRIPE_API_KEY=

# Google Analytics: Webseiten-Traffic, Conversions, Nutzer-Verhalten
# Nutzt eine Service-Account-JSON-Datei, keinen einfachen Key
# Anleitung: https://developers.google.com/analytics/devguides/reporting/data/v1/quickstart-client-libraries
# Genutzt von: Daten (Google-Analytics-Sammler)
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Google Sheets: Daten aus Tabellen (P&L, KPIs, etc.)
# Nutzt denselben Google-Service-Account wie Google Analytics oben
# Genutzt von: Daten (Sheets-Sammler)
GOOGLE_SHEETS_CREDENTIALS=

# Bitly: Link-Klicks und Attribution
# Holen unter: https://app.bitly.com/settings/api/
# "Generate token" klicken
# Genutzt von: Daten (Bitly-Sammler)
BITLY_ACCESS_TOKEN=


# ─── KOMMUNIKATION UND INTELLIGENZ ──────────────────────────────────────────
# Meeting-Aufzeichnungen, Slack-Nachrichten, Handy-Zugang.

# Fireflies.ai: Meeting-Transkripte sammeln
# Holen unter: https://app.fireflies.ai/integrations, dann API & Webhooks, API-Key kopieren
# Genutzt von: Intelligenz (Meeting-Sammler)
FIREFLIES_API_KEY=

# Slack: Nachrichten und Workspace-Monitoring
# Slack-App anlegen: https://api.slack.com/apps, dann "Create New App"
# Genutzt von: Intelligenz (Slack-Sammler)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Telegram-Bot: Handy-Schnittstelle, Sprachnachrichten, Benachrichtigungen
# Bot anlegen: schreib @BotFather auf Telegram an, /newbot, Token kopieren
# Genutzt von: Stimme (Telegram-Bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ─── RECHERCHE UND SCRAPING ─────────────────────────────────────────────────
# Für Content-Recherche, Wettbewerbsanalyse, Web-Daten.

# Apify: Web-Scraping (LinkedIn, Reddit, Foren, beliebige Seiten)
# Holen unter: https://console.apify.com/account/integrations
# Genutzt von: Recherche-Befehle, Content-Analyse
APIFY_API_TOKEN=

# Supadata: YouTube-Transkripte, Social-Media-Daten, Web-Scraping
# Holen unter: https://supadata.ai/dashboard, dann API Keys
# Genutzt von: Content-Pipeline (Transkripte), Recherche
SUPADATA_API_KEY=


# ─── CONTENT UND VERÖFFENTLICHEN ────────────────────────────────────────────
# Für Content-Erstellung und Distribution.

# Notion: Content-Kalender, Task-Sync
# Integration anlegen: https://www.notion.so/my-integrations, dann "New integration"
# Genutzt von: Content-Pipeline (Plan-Sync)
NOTION_API_KEY=

# Kit (ConvertKit): Newsletter-Broadcasts
# Holen unter: https://app.kit.com/account/developer_settings
# Genutzt von: Newsletter-Automatisierung
KIT_API_KEY=
KIT_API_SECRET=

# HeyGen: KI-Avatar-Videos generieren
# Holen unter: https://app.heygen.com/settings, dann API
# Genutzt von: Modul-Video-Fabrik
HEYGEN_API_KEY=


# ─── OPTIONAL UND FORTGESCHRITTEN ───────────────────────────────────────────
# Nützlich, aber nicht zwingend zum Starten.

# ElevenLabs: Text-zu-Sprache (hochqualitative Stimme)
# Holen unter: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Deepgram: Speech-to-Text (Alternative zu Whisper)
# Holen unter: https://console.deepgram.com/
DEEPGRAM_API_KEY=
