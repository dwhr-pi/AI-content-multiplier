# AI-ContentMultiplier local example configuration
# Copy to ~/.openclaw_ultimate_user_data/content-multiplier/.env
# Do not commit real secrets.

CONTENT_MULTIPLIER_MODE=local
CONTENT_MULTIPLIER_OUTPUT_DIR=./output

# Local model default
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:1b

# Optional cloud providers. Leave empty unless intentionally enabled.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-3-5-haiku-latest

# Extraction providers
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# Integrations
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
N8N_WEBHOOK_URL=
HOME_ASSISTANT_URL=http://127.0.0.1:8123
HOME_ASSISTANT_TOKEN=
NEXTCLOUD_BASE_URL=
NEXTCLOUD_USERNAME=
NEXTCLOUD_APP_PASSWORD=

# Safety defaults
ALLOW_CLOUD_MODE=false
ALLOW_AUTO_PUBLISH=false
REQUIRE_HUMAN_REVIEW=true
