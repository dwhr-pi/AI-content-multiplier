# Queue Job Manager Beispielkonfiguration

QUEUE_BASE_DIR="$HOME/.ultimate-ki/queue-job-manager"

# Globale Parallelitaet
QUEUE_MAX_PARALLEL_JOBS=2

# Ressourcenklassen
QUEUE_MAX_LIGHT_JOBS=4
QUEUE_MAX_MEDIUM_JOBS=2
QUEUE_MAX_HEAVY_JOBS=1
QUEUE_MAX_GPU_JOBS=1

# Worker-Verhalten
QUEUE_DEFAULT_RETRY_LIMIT=1
QUEUE_POLL_INTERVAL_SECONDS=5
QUEUE_LOG_TAIL_LINES=80

# Hinweis:
# Diese Datei nach ~/.ultimate-ki/queue-job-manager/queue.env kopieren
# und dort lokal anpassen.
